<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="card form-card" id="moderation-shell" data-event-id="<%= editingEvent.id %>">
  <div>
    <p class="eyebrow">Moderation</p>
    <h1>Moderation des photos</h1>
    <p>Evenement : <strong><%= editingEvent.name %></strong>.</p>
    <p>
      <% if (editingEvent.moderationEnabled) { %>
        La moderation est active : seules les photos approuvees seront visibles sur le slideshow et la galerie publique.
      <% } else { %>
        La moderation est desactivee : les nouvelles photos sont publiees directement. Vous pouvez tout de meme approuver ou rejeter manuellement des photos existantes.
      <% } %>
    </p>
  </div>

  <div class="table-actions">
    <a class="btn btn-secondary" href="/profile/events/<%= editingEvent.id %>/edit">Retour a l'edition</a>
    <a class="btn btn-secondary" href="/profile/events/<%= editingEvent.id %>/gallery">Voir la galerie proprietaire</a>
  </div>

  <p id="moderation-empty" class="section-gap" <%= moderationFiles.length ? 'hidden' : '' %>>Aucune photo en attente de moderation pour le moment.</p>

  <div id="moderation-pending-grid" class="event-gallery-grid section-gap" <%= moderationFiles.length ? '' : 'hidden' %>>
    <% moderationFiles.forEach((fileItem) => { %>
      <article class="event-gallery-card" data-file-id="<%= fileItem.id %>" data-stored-name="<%= fileItem.storedName %>">
          <a href="<%= fileItem.urls.xl || fileItem.urls.original %>" target="_blank" rel="noopener noreferrer">
            <img
              src="<%= fileItem.urls.sm || fileItem.urls.md || fileItem.urls.original %>"
              alt="<%= fileItem.originalName %>"
              loading="lazy"
              onerror="this.onerror=null;this.src='<%= fileItem.urls.original %>';"
            />
          </a>
          <div class="event-gallery-meta">
            <strong><%= fileItem.originalName %></strong>
            <small>En attente d'approbation</small>
            <small>Par <%= fileItem.uploaderName || 'Visiteur' %> · <%= new Date(fileItem.createdAt).toLocaleString('fr-FR') %></small>
          </div>
          <div class="table-actions">
            <form method="post" action="/profile/event/<%= editingEvent.id %>/moderation/<%= fileItem.id %>" class="inline-form js-moderation-action-form" data-file-id="<%= fileItem.id %>">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="moderationStatus" value="approved" />
              <button class="btn btn-small" type="submit">Approuver</button>
            </form>
            <form method="post" action="/profile/event/<%= editingEvent.id %>/moderation/<%= fileItem.id %>" class="inline-form js-moderation-action-form" data-file-id="<%= fileItem.id %>">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="moderationStatus" value="rejected" />
              <button class="btn btn-danger btn-small" type="submit">Rejeter</button>
            </form>
          </div>
      </article>
    <% }) %>
  </div>
</section>

<%- include('partials/footer') %>