<%- include('../../partials/header', { pageTitle }) %>
<%- include('../../partials/alerts') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h4 mb-0">Gestion des utilisateurs</h1>
  <a href="/admin/users/new" class="btn btn-primary">Nouvel utilisateur</a>
</div>

<div class="card shadow-sm">
  <div class="table-responsive">
    <table class="table table-striped align-middle mb-0">
      <thead>
        <tr>
          <th>ID</th>
          <th>Username</th>
          <th>Nom complet</th>
          <th>Email</th>
          <th>Rôle</th>
          <th>Actif</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach((user) => { %>
          <tr>
            <td><%= user.id %></td>
            <td><%= user.username %></td>
            <td><%= user.fullName %></td>
            <td><%= user.email %></td>
            <td><span class="badge text-bg-<%= user.role === 'admin' ? 'dark' : 'secondary' %>"><%= user.role %></span></td>
            <td><span class="badge text-bg-<%= user.isActive ? 'success' : 'danger' %>"><%= user.isActive ? 'Oui' : 'Non' %></span></td>
            <td class="d-flex gap-2">
              <a class="btn btn-sm btn-outline-primary" href="/admin/users/<%= user.id %>/edit">Modifier</a>
              <form action="/admin/users/<%= user.id %>/delete" method="post" onsubmit="return confirm('Supprimer cet utilisateur ?');">
                <button class="btn btn-sm btn-outline-danger" type="submit">Supprimer</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../../partials/footer') %>
