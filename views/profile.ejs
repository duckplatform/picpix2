<%- include('partials/head') %>
<%- include('partials/header') %>
<section class="grid-columns">
  <article class="card">
    <p class="eyebrow">Compte</p>
    <h1>Mon profil</h1>
    <dl class="definition-list">
      <div>
        <dt>Email</dt>
        <dd><%= user.email %></dd>
      </div>
      <div>
        <dt>Role</dt>
        <dd><%= user.role %></dd>
      </div>
      <div>
        <dt>Statut</dt>
        <dd><%= user.status %></dd>
      </div>
    </dl>
  </article>

  <article class="card">
    <p class="eyebrow">Edition</p>
    <h2>Mettre a jour mon profil</h2>
    <form method="post" action="/profile?_method=PUT" class="form-grid">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <label>
        <span>Nom complet</span>
        <input type="text" name="fullName" value="<%= formData.fullName || user.fullName || '' %>" required maxlength="120" />
        <% if (fieldErrors.fullName) { %><small class="field-error"><%= fieldErrors.fullName %></small><% } %>
      </label>

      <label>
        <span>Nouveau mot de passe</span>
        <input type="password" name="password" minlength="8" maxlength="72" />
        <% if (fieldErrors.password) { %><small class="field-error"><%= fieldErrors.password %></small><% } %>
      </label>

      <label>
        <span>Confirmation du nouveau mot de passe</span>
        <input type="password" name="confirmPassword" minlength="8" maxlength="72" />
        <% if (fieldErrors.confirmPassword) { %><small class="field-error"><%= fieldErrors.confirmPassword %></small><% } %>
      </label>

      <label>
        <span>Mot de passe actuel</span>
        <input type="password" name="currentPassword" maxlength="72" />
        <% if (fieldErrors.currentPassword) { %><small class="field-error"><%= fieldErrors.currentPassword %></small><% } %>
      </label>

      <button class="btn" type="submit">Enregistrer</button>
    </form>
  </article>
</section>
<%- include('partials/footer') %>