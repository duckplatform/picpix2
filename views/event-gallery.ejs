<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="card form-card">
  <div>
    <p class="eyebrow">Galerie evenement</p>
    <p>Consultez les photos optimisees pour un affichage rapide sur mobile.</p>
  </div>

  <% if (!galleryFiles.length) { %>
    <p>Aucune photo disponible pour le moment.</p>
  <% } else { %>
    <div class="event-gallery-grid">
      <% galleryFiles.forEach((fileItem) => { %>
        <article class="event-gallery-card">
          <a href="<%= fileItem.urls.xl || fileItem.urls.original %>" target="_blank" rel="noopener noreferrer">
            <img
              src="<%= fileItem.urls.sm || fileItem.urls.md || fileItem.urls.original %>"
              alt="<%= fileItem.originalName %>"
              loading="lazy"
            />
          </a>
          <div class="event-gallery-meta">
            <strong><%= fileItem.originalName %></strong>
            <small>
              <%= fileItem.isProcessed ? 'Version optimisee disponible' : 'Optimisation en cours...' %>
            </small>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>