<%- include('partials/header', { pageTitle }) %>
<%- include('partials/alerts') %>

<section class="hero p-4 p-md-5 rounded-4 text-white mb-4">
  <h1 class="display-6 fw-bold">Application utilisateurs Node.js + MySQL</h1>
  <p class="lead mb-0">Inscription, connexion, gestion de profil et administration CRUD des utilisateurs.</p>
</section>

<div class="row g-4">
  <div class="col-md-6">
    <div class="card h-100 shadow-sm">
      <div class="card-body">
        <h2 class="h5">Espace utilisateur</h2>
        <p>Chaque utilisateur peut créer un compte, se connecter et mettre à jour son profil.</p>
        <% if (!currentUser) { %>
          <a href="/register" class="btn btn-primary">Créer un compte</a>
        <% } else { %>
          <a href="/profile" class="btn btn-primary">Accéder à mon profil</a>
        <% } %>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card h-100 shadow-sm">
      <div class="card-body">
        <h2 class="h5">Espace administration</h2>
        <p>Le rôle admin peut gérer les utilisateurs (création, modification, suppression, activation).</p>
        <% if (currentUser && currentUser.role === 'admin') { %>
          <a href="/admin/users" class="btn btn-dark">Aller à l'admin</a>
        <% } else { %>
          <span class="badge text-bg-secondary">Accès réservé admin</span>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
